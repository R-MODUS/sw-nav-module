  <gazebo reference="cliff_sensor_rr_mount_joint">
    <preserveFixedJoint>true</preserveFixedJoint>
  </gazebo>
  <gazebo reference="cliff_sensor_rr_beam_joint">
    <preserveFixedJoint>true</preserveFixedJoint>
  </gazebo>
  <gazebo reference="cliff_sensor_rr_beam">
    <sensor name="cliff_rr" type="gpu_ray">
      <always_on>1</always_on>
      <update_rate>20</update_rate>
      <visualize>true</visualize>
      <ray>
        <scan>
          <horizontal>
            <samples>1</samples>
            <resolution>1</resolution>
            <min_angle>0</min_angle>
            <max_angle>0</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.01</min>
          <max>0.5</max>
          <resolution>0.001</resolution>
        </range>
      </ray>
      <topic>/cliff/rr</topic>
      <gz_frame_id>cliff_sensor_rr_beam</gz_frame_id>
    </sensor>
  </gazebo>
  <!-- mecanum or diff/differential -->
  <!-- JOINT STATE plugin -->
  <gazebo>
    <plugin filename="libgz-sim-joint-state-publisher-system.so" name="gz::sim::systems::JointStatePublisher">
      <topic>/joint_states</topic>
    </plugin>
  </gazebo>
  <gazebo>
    <plugin filename="libgz-sim-mecanum-drive-system.so" name="gz::sim::systems::MecanumDrive">
      <front_left_joint>front_left_wheel_joint</front_left_joint>
      <front_right_joint>front_right_wheel_joint</front_right_joint>
      <back_left_joint>rear_left_wheel_joint</back_left_joint>
      <back_right_joint>rear_right_wheel_joint</back_right_joint>
      <wheel_separation>0.38</wheel_separation>
      <wheelbase>0.24</wheelbase>
      <wheel_radius>0.055</wheel_radius>
      <odom_publish_frequency>30</odom_publish_frequency>
      <topic>/cmd_vel</topic>
      <odom_topic>/odom</odom_topic>
      <tf_topic>__unused_tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
    </plugin>
  </gazebo>
  <gazebo reference="front_left_wheel">
    <collision>
      <surface>
        <friction>
          <ode>
            <mu>1.1</mu>
            <mu2>0.15</mu2>
            <fdir1 gz:expressed_in="base_footprint">1 -1 0</fdir1>
          </ode>
        </friction>
      </surface>
    </collision>
  </gazebo>
  <gazebo reference="front_right_wheel">
    <collision>
      <surface>
        <friction>
          <ode>
            <mu>1.1</mu>
            <mu2>0.15</mu2>
            <fdir1 gz:expressed_in="base_footprint">1 1 0</fdir1>
          </ode>
        </friction>
      </surface>
    </collision>
  </gazebo>
  <gazebo reference="rear_left_wheel">
    <collision>
      <surface>
        <friction>
          <ode>
            <mu>1.1</mu>
            <mu2>0.15</mu2>
            <fdir1 gz:expressed_in="base_footprint">1 1 0</fdir1>
          </ode>
        </friction>
      </surface>
    </collision>
  </gazebo>
  <gazebo reference="rear_right_wheel">
    <collision>
      <surface>
        <friction>
          <ode>
            <mu>1.1</mu>
            <mu2>0.15</mu2>
            <fdir1 gz:expressed_in="base_footprint">1 -1 0</fdir1>
          </ode>
        </friction>
      </surface>
    </collision>
  </gazebo>
</robot>
