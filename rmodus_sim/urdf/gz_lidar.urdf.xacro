<?xml version='1.0'?>
<!-- Sim-only: Gazebo lidar sensor plugin.
     TF link/joint defined in rmodus_description/urdf/lidar.urdf.xacro -->

<robot xmlns:xacro='http://www.ros.org/wiki/xacro'
       xmlns:gz='http://gazebosim.org/schema'>

<gazebo>
  <plugin
    filename='libgz-sim-sensors-system.so'
    name='gz::sim::systems::Sensors'>
    <render_engine>ogre2</render_engine>
  </plugin>
</gazebo>

<gazebo reference='lidar_beam'>
  <sensor name='lidar' type='gpu_ray'>
    <always_on>1</always_on>
    <visualize>${str(lidar_cfg.get("visualize", False)).lower()}</visualize>
    <update_rate>${lidar_cfg.get("update_rate", 10)}</update_rate>
    <ray>
      <scan>
        <horizontal>
          <samples>${max(1, int(round(lidar_cfg.get("fov", 360) / max(lidar_cfg.get("resolution", 1.0), 1e-6))))}</samples>
          <resolution>1.0</resolution>
          <min_angle>${lidar_cfg.get("angle_min", 0.0)}</min_angle>
          <max_angle>${lidar_cfg.get("angle_max", 2 * pi)}</max_angle>
        </horizontal>
      </scan>
      <range>
        <min>${lidar_cfg.get("range_min", 0.05)}</min>
        <max>${lidar_cfg.get("range_max", 5.0)}</max>
      </range>
    </ray>
    <topic>${lidar_cfg.get("topic", "/scan")}</topic>
    <gz_frame_id>lidar_beam</gz_frame_id>
  </sensor>
</gazebo>

</robot>
