  </gazebo>
  <gazebo reference="bumper_rear_mount">
    <sensor name="bumper_rear_sensor" type="contact">
      <always_on>1</always_on>
      <update_rate>30</update_rate>
      <topic>/bumper/rear</topic>
      <contact>
        <collision>bumper_rear_mount_collision</collision>
      </contact>
    </sensor>
  </gazebo>
  <gazebo reference="bumper_left_mount_joint">
    <preserveFixedJoint>true</preserveFixedJoint>
  </gazebo>
  <gazebo reference="bumper_left_contact_joint">
    <preserveFixedJoint>true</preserveFixedJoint>
  </gazebo>
  <gazebo reference="bumper_left_mount">
    <sensor name="bumper_left_sensor" type="contact">
      <always_on>1</always_on>
      <update_rate>30</update_rate>
      <topic>/bumper/left</topic>
      <contact>
        <collision>bumper_left_mount_collision</collision>
      </contact>
    </sensor>
  </gazebo>
  <gazebo reference="bumper_right_mount_joint">
    <preserveFixedJoint>true</preserveFixedJoint>
  </gazebo>
  <gazebo reference="bumper_right_contact_joint">
    <preserveFixedJoint>true</preserveFixedJoint>
  </gazebo>
  <gazebo reference="bumper_right_mount">
    <sensor name="bumper_right_sensor" type="contact">
      <always_on>1</always_on>
      <update_rate>30</update_rate>
