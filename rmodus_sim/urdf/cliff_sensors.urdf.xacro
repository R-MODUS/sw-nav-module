<?xml version='1.0'?>
<!-- Shared cliff sensor TF frames - no Gazebo plugins -->

<robot xmlns:xacro='http://www.ros.org/wiki/xacro'>

<xacro:property name='cliff_sensor_mass' value='0.001'/>

<xacro:macro name='render_cliff_sensor' params='c'>
  <link name='cliff_sensor_${c["name"]}_mount'>
    <xacro:box_inertia m='${cliff_sensor_mass}' x='${c["size"][0]}' y='${c["size"][1]}' z='${c["size"][2]}'/>
    <visual>
      <origin xyz='${c["size"][0]/2} 0 ${-c["size"][2]/2}' rpy='0 0 0'/>
      <geometry><box size='${c["size"][0]} ${c["size"][1]} ${c["size"][2]}'/></geometry>
      <material name='cliff_mount_mat'/>
    </visual>
    <collision>
      <origin xyz='${c["size"][0]/2} 0 ${-c["size"][2]/2}' rpy='0 0 0'/>
      <geometry><box size='${c["size"][0]} ${c["size"][1]} ${c["size"][2]}'/></geometry>
    </collision>
  </link>

  <joint name='cliff_sensor_${c["name"]}_mount_joint' type='fixed'>
    <parent link='${c.get("mount_parent_frame", c.get("parent_frame", "base_link"))}'/>
    <child link='cliff_sensor_${c["name"]}_mount'/>
    <origin xyz='${c.get("mount_offset", c.get("offset", [0.0, 0.0, 0.0]))[0]} ${c.get("mount_offset", c.get("offset", [0.0, 0.0, 0.0]))[1]} ${c.get("mount_offset", c.get("offset", [0.0, 0.0, 0.0]))[2]}'
            rpy='${c.get("mount_rpy", [0.0, 0.0, c.get("yaw", 0.0)])[0]} ${c.get("mount_rpy", [0.0, 0.0, c.get("yaw", 0.0)])[1]} ${c.get("mount_rpy", [0.0, 0.0, c.get("yaw", 0.0)])[2]}'/>
  </joint>

  <link name='cliff_sensor_${c["name"]}_beam'>
    <inertial>
      <mass value='0.001'/>
      <inertia ixx='0.00001' ixy='0' ixz='0' iyy='0.00001' iyz='0' izz='0.00001'/>
    </inertial>
  </link>

  <joint name='cliff_sensor_${c["name"]}_beam_joint' type='fixed'>
    <parent link='cliff_sensor_${c["name"]}_mount'/>
    <child link='cliff_sensor_${c["name"]}_beam'/>
    <origin xyz='${c.get("beam_offset", [c["size"][0], 0.0, -c["size"][2]/2])[0]} ${c.get("beam_offset", [c["size"][0], 0.0, -c["size"][2]/2])[1]} ${c.get("beam_offset", [c["size"][0], 0.0, -c["size"][2]/2])[2]}'
            rpy='${c.get("beam_rpy", [0.0, pi/2, 0.0])[0]} ${c.get("beam_rpy", [0.0, pi/2, 0.0])[1]} ${c.get("beam_rpy", [0.0, pi/2, 0.0])[2]}'/>
  </joint>
</xacro:macro>

<xacro:macro name='cliff_sensor_loop' params='items'>
  <xacro:if value='${items}'>
    <xacro:property name='current_c' value='${items.pop(0)}'/>
    <xacro:render_cliff_sensor c='${current_c}'/>
    <xacro:cliff_sensor_loop items='${items}'/>
  </xacro:if>
</xacro:macro>

<xacro:cliff_sensor_loop items='${list(cliff_sensors)}'/>

</robot>
