  <gazebo reference="cliff_sensor_fl_mount_joint">
    <preserveFixedJoint>true</preserveFixedJoint>
  </gazebo>
  <gazebo reference="cliff_sensor_fl_beam_joint">
    <preserveFixedJoint>true</preserveFixedJoint>
  </gazebo>
  <gazebo reference="cliff_sensor_fl_beam">
    <sensor name="cliff_fl" type="gpu_ray">
      <always_on>1</always_on>
      <update_rate>20</update_rate>
      <visualize>true</visualize>
      <ray>
        <scan>
          <horizontal>
            <samples>1</samples>
            <resolution>1</resolution>
            <min_angle>0</min_angle>
            <max_angle>0</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.01</min>
          <max>0.5</max>
          <resolution>0.001</resolution>
        </range>
      </ray>
      <topic>/cliff/fl</topic>
      <gz_frame_id>cliff_sensor_fl_beam</gz_frame_id>
    </sensor>
  </gazebo>
  <gazebo reference="cliff_sensor_fr_mount_joint">
    <preserveFixedJoint>true</preserveFixedJoint>
  </gazebo>
  <gazebo reference="cliff_sensor_fr_beam_joint">
    <preserveFixedJoint>true</preserveFixedJoint>
  </gazebo>
  <gazebo reference="cliff_sensor_fr_beam">
    <sensor name="cliff_fr" type="gpu_ray">
      <always_on>1</always_on>
      <update_rate>20</update_rate>
      <visualize>true</visualize>
      <ray>
        <scan>
          <horizontal>
            <samples>1</samples>
            <resolution>1</resolution>
            <min_angle>0</min_angle>
            <max_angle>0</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.01</min>
          <max>0.5</max>
          <resolution>0.001</resolution>
        </range>
      </ray>
      <topic>/cliff/fr</topic>
      <gz_frame_id>cliff_sensor_fr_beam</gz_frame_id>
    </sensor>
  </gazebo>
  <gazebo reference="cliff_sensor_rl_mount_joint">
    <preserveFixedJoint>true</preserveFixedJoint>
  </gazebo>
  <gazebo reference="cliff_sensor_rl_beam_joint">
    <preserveFixedJoint>true</preserveFixedJoint>
  </gazebo>
  <gazebo reference="cliff_sensor_rl_beam">
    <sensor name="cliff_rl" type="gpu_ray">
      <always_on>1</always_on>
      <update_rate>20</update_rate>
      <visualize>true</visualize>
      <ray>
        <scan>
          <horizontal>
            <samples>1</samples>
            <resolution>1</resolution>
            <min_angle>0</min_angle>
            <max_angle>0</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.01</min>
          <max>0.5</max>
          <resolution>0.001</resolution>
        </range>
